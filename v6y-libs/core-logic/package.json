{
  "name": "@v6y/core-logic",
  "version": "0.0.1",
  "main": "src/index.ts",
  "type": "module",
  "files": [
    "src",
    "dist",
    "README.md"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/ekino/v6y"
  },
  "scripts": {
    "build:tsc": "tsc --project ./tsconfig.json",
    "check:tsc": "tsc --noEmit --project ./tsconfig.json",
    "db:generate": "prisma generate --schema=./prisma/schema.prisma",
    "db:migrate": "prisma migrate dev --schema=./prisma/schema.prisma",
    "db:migrate:deploy": "prisma migrate deploy --schema=./prisma/schema.prisma",
    "db:seed": "tsx prisma/seed.ts",
    "db:reset": "prisma migrate reset --schema=./prisma/schema.prisma --force",
    "lint": "eslint --config ./eslint.config.mjs --cache-location ./.eslintcache \"./**/*.ts\" --cache",
    "lint:fix": "eslint --config ./eslint.config.mjs --cache-location ./.eslintcache \"./**/*.ts\" --cache --fix",
    "format": "prettier --write ./src",
    "test": "vitest --coverage --watch false",
    "test:watch": "vitest",
    "test:ui": "vitest --ui"
  },
  "prisma": {
    "schema": "./prisma/schema.prisma",
    "seed": "tsx prisma/seed.ts"
  },
  "devDependencies": {
    "@eslint/js": "=10.0.1",
    "@trivago/prettier-plugin-sort-imports": "=6.0.0",
    "@types/bcrypt": "=6.0.0",
    "@types/jsonwebtoken": "=9.0.7",
    "@types/passport": "=1.0.17",
    "@types/passport-jwt": "=4.0.1",
    "@types/pg": "^8.20.0",
    "@vitest/coverage-v8": "=3.0.5",
    "@vitest/ui": "=4.0.14",
    "chai": "=6.2.1",
    "eslint": "=10.0.1",
    "eslint-config-prettier": "=10.0.1",
    "eslint-plugin-prettier": "=5.2.1",
    "globals": "=16.4.0",
    "prisma": "^7.8.0",
    "tsx": "^4.21.0",
    "typescript": "=5.7.3",
    "typescript-eslint": "=8.56.0",
    "vitest": "=3.0.5"
  },
  "dependencies": {
    "@prisma/adapter-pg": "^7.8.0",
    "@prisma/client": "=7.8.0",
    "@types/adm-zip": "=0.5.7",
    "@types/cors": "=2.8.17",
    "@types/file-saver": "=2.0.7",
    "@types/fs-extra": "=11.0.4",
    "@types/lodash": "=4.17.14",
    "@types/semver": "=7.5.8",
    "@types/spdy": "=3.4.9",
    "@types/unixify": "=1.0.2",
    "adm-zip": "=0.5.16",
    "axios": "=1.15.2",
    "axios-retry": "=4.5.0",
    "bcrypt": "=6.0.0",
    "compare-versions": "=6.1.1",
    "cors": "=2.8.5",
    "dotenv": "=17.2.3",
    "file-saver": "=2.0.5",
    "fs-extra": "=11.2.0",
    "globals": "=16.4.0",
    "globby": "=16.0.0",
    "json-2-csv": "=5.5.7",
    "jsonwebtoken": "=9.0.2",
    "lodash": "=4.18.1",
    "morgan": "=1.10.0",
    "package-manager-detector": "=1.2.0",
    "passport": "=0.7.0",
    "passport-jwt": "=4.0.1",
    "pg": "=8.13.1",
    "pg-hstore": "=2.3.4",
    "semver": "=7.6.3",
    "spdy": "=4.0.2",
    "superagent": "=10.1.1",
    "unixify": "=1.0.0",
    "winston": "=3.17.0",
    "winston-daily-rotate-file": "=5.0.0",
    "winston-transport": "=4.9.0"
  }
}
