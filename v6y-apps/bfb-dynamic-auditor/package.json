    "src",
    "dist",
    "README.md"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/ekino/v6y"
  },
  "scripts": {
    "build:tsc": "tsc --project ./tsconfig.json",
    "check:tsc": "tsc --noEmit --project ./tsconfig.json",
    "start:dev": "tsx watch --env-file=./.env src/index.ts -- --dev",
    "start": "tsx watch --env-file=./.env src/index.ts --",
    "code:analyze": "es6-plato -r -d target/report src",
    "lint": "eslint --config ./eslint.config.mjs --cache-location ./.eslintcache \"./**/*.ts\" --cache",
    "lint:fix": "eslint --config ./eslint.config.mjs --cache-location ./.eslintcache \"./**/*.ts\" --cache --fix",
    "format": "prettier --write ./src",
    "test": "vitest --coverage --watch false"
  },
  "devDependencies": {
    "@eslint/js": "=10.0.1",
    "@trivago/prettier-plugin-sort-imports": "=6.0.0",
    "@types/cookie-parser": "=1.4.8",
    "@types/express": "=5.0.5",
    "@types/express-status-monitor": "=1.3.3",
    "@types/supertest": "=6.0.2",
    "@vitest/coverage-v8": "=4.1.0",
    "@vitest/ui": "=4.1.0",
    "chai": "=6.2.1",
    "es6-plato": "=1.2.3",
    "eslint": "=10.0.1",
    "eslint-config-prettier": "=10.0.1",
    "eslint-plugin-prettier": "=5.2.1",
    "globals": "=16.4.0",
    "lighthouse": "=13.0.3",
    "puppeteer-core": "=24.0.0",
    "supertest": "=7.0.0",
    "tsx": "=4.21.0",
    "typescript": "=5.7.3",
    "typescript-eslint": "=8.56.0",
    "vitest": "=4.1.0"
  },
  "dependencies": {
    "@nestjs/common": "=11.1.26",
    "@nestjs/core": "=11.1.26",
    "@nestjs/platform-express": "=11.1.26",
    "@prisma/client": "=7.8.0",
    "@v6y/core-logic": "workspace:^",
    "axios": "=1.16.1",
    "axios-retry": "=4.5.0",
    "cookie-parser": "=1.4.7",
    "cron": "=4.3.3",
