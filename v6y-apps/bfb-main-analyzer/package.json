    "@types/node-cron": "catalog:",
    "@types/supertest": "catalog:testing",
    "@vitest/coverage-v8": "catalog:testing",
    "@vitest/ui": "catalog:testing",
    "eslint": "catalog:eslint10",
    "eslint-config-prettier": "catalog:eslint10",
    "globals": "catalog:",
    "supertest": "catalog:testing",
    "tsx": "catalog:",
    "typescript": "catalog:",
    "typescript-eslint": "catalog:eslint10",
    "vitest": "catalog:testing"
  },
  "dependencies": {
    "@nestjs/common": "catalog:nestjs11",
    "@nestjs/core": "catalog:nestjs11",
    "@nestjs/platform-express": "catalog:nestjs11",
    "@v6y/core-logic": "workspace:^",
    "cookie-parser": "catalog:",
